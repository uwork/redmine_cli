{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cargo fmt 2>&1 && cargo clippy -- -D warnings 2>&1 && cargo test 2>&1 || exit 2",
            "timeout": 300,
            "asyncRewake": true,
            "statusMessage": "Running cargo fmt / clippy / test..."
          }
        ]
      }
    ]
  }
}
